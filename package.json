{
  "name": "smart-pharmacy-system",
  "version": "1.0.0",
  "description": "Smart Pharmacy Shop Management System with Glassmorphism UI",
  "scripts": {
    "install:all": "npm install && npm run install:backend && npm run install:frontend",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install --legacy-peer-deps",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
