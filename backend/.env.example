# System Ports & Secret Key
PORT=5000
JWT_SECRET=pharmacy-super-secret-key-12345

# =========================================================================
# SMS/OTP AUTOMATIC SENDING GATEWAYS
# =========================================================================
# Configure ONE of the gateways below to send real SMS. Leave others empty.

# Option 1: Fast2SMS
FAST2SMS_API_KEY=

# Option 2: TextBelt
TEXTBELT_API_KEY=

# Option 3: Vonage (Nexmo)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=RxSmart

# Option 4: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =========================================================================
# EMAIL RECEIPT AUTOMATIC SENDING GATEWAY (SMTP / Nodemailer / Google Apps Script)
# =========================================================================
# To send real billing emails automatically, configure Gmail SMTP OR Google Apps Script API below.

# Option 1: Gmail SMTP Setup (Nodemailer)
# 1. Enter your Gmail address below:
EMAIL_USER=
# 2. Enter your 16-character App Password (NOT your login password).
#    Generate it here: https://myaccount.google.com/apppasswords
EMAIL_PASS=

# Option 2: Google Apps Script API
# Set the URL if you have a Google Apps Script deployment to handle sending emails.
EMAIL_API_URL=
